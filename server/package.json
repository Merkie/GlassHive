{
  "name": "glasshive-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "2.3.3",
    "@prisma/client": "^6.19.3",
    "ai": "6.0.160",
    "cors": "^2.8.5",
    "cryptr": "^6.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0"
  }
}
