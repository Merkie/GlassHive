# OpenRouter API key used when a visitor submits the admin password
# (or for legacy single-tenant runs). Required.
OPENROUTER_API_KEY=

# Used to symmetrically encrypt visitor-supplied OpenRouter keys before
# they're handed back for localStorage persistence. Rotate to invalidate
# every stored client blob. Required, at least 16 chars; 32 random bytes
# (hex) is the recommended size: `openssl rand -hex 32`.
MASTER_ENCRYPTION_KEY=

# Bypass password — when a visitor types this on the BYOK gate, the
# server uses OPENROUTER_API_KEY for their runs instead of treating
# their input as a real key. Required.
ADMIN_PASSWORD=

PORT=3811
DATABASE_URL="file:./dev.db"
