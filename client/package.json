    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.1.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.4.5",
    "vite": "^7.2.4",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.2.4"
